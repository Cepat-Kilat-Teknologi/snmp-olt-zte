# ==============================================================================
# GO-SNMP-OLT-ZTE-C320 - Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust the values for your environment.
# Required variables are marked with [REQUIRED], others have sensible defaults.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Environment
# ------------------------------------------------------------------------------
# Controls logging verbosity and connection behavior.
# Values: development | production | test
APP_ENV=development

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
# The server listens on :SERVER_PORT on all interfaces (0.0.0.0). SERVER_HOST is
# informational only — it is not read by the app; restrict exposure via your
# network/ingress, not this value.
SERVER_HOST=0.0.0.0
SERVER_PORT=8081

# ------------------------------------------------------------------------------
# SNMP Configuration [REQUIRED]
# ------------------------------------------------------------------------------
# Connection settings for the ZTE C320 OLT device.
# SNMP_HOST: IP address of the OLT (e.g., 192.168.1.1 or 10.10.10.1)
# SNMP_PORT: SNMP agent port (default: 161)
# SNMP_COMMUNITY: SNMP v2c community string for read access
SNMP_HOST=192.168.1.1
SNMP_PORT=161
SNMP_COMMUNITY=public
# SNMP_MAX_CONCURRENT: Maximum concurrent SNMP operations to OLT device
# Prevents OLT saturation under high API load. Increase if OLT can handle more.
SNMP_MAX_CONCURRENT=5
# SNMP_TIMEOUT_SECONDS: Per-request SNMP timeout (default: 5). Raise for slow/public links.
SNMP_TIMEOUT_SECONDS=5
# SNMP_RETRIES: Per-request SNMP retry count (default: 2).
SNMP_RETRIES=2
# SNMP_MAX_REPETITIONS: GETBULK max-repetitions for BulkWalk (default: 20).
# MUST be > 0: a GetBulk with max-repetitions=0 HANGS on some ZTE OLTs
# (proven on a ZTE C300 V2.1.0 — -Cr0 never returns, -Cr10/-Cr50 return in
# <0.1s). The default 20 makes GetBulk usable, so the per-OLT walk=true
# (GetNext) workaround is no longer needed just to read these devices.
# Any value <= 0 or non-numeric falls back to the safe default.
SNMP_MAX_REPETITIONS=20

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
# Used for caching ONU data to reduce SNMP polling load.
# REDIS_HOST: Redis server hostname or IP
# REDIS_PORT: Redis server port
# REDIS_PASSWORD: Leave empty if no authentication required
# REDIS_DB: Redis database index (0-15)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Connection pool settings (tune based on concurrent load)
# REDIS_MIN_IDLE_CONNECTIONS: Minimum idle connections kept open
# REDIS_POOL_SIZE: Maximum number of connections in the pool
# REDIS_POOL_TIMEOUT: Timeout in seconds when waiting for a pool connection
REDIS_MIN_IDLE_CONNECTIONS=10
REDIS_POOL_SIZE=100
REDIS_POOL_TIMEOUT=30

# Cache TTL settings (higher = less SNMP polling, more stale data)
# REDIS_ONU_INFO_TTL: TTL for ONU list cache per board/pon (default: 1800 = 30min)
# REDIS_ONU_DETAIL_TTL: TTL for individual ONU detail cache (default: 900 = 15min)
# REDIS_EMPTY_ONU_ID_TTL: TTL for empty ONU ID cache (default: 300 = 5min)
REDIS_ONU_INFO_TTL=1800
REDIS_ONU_DETAIL_TTL=900
REDIS_EMPTY_ONU_ID_TTL=300

# Pre-warm cache on startup (scans all 32 board/pon combos into Redis)
# Eliminates cold-start latency for first requests
CACHE_PREWARM=true

# ------------------------------------------------------------------------------
# TLS/HTTPS Configuration
# ------------------------------------------------------------------------------
# Enable HTTPS for production deployments.
# USE_TLS: Set to "true" to enable HTTPS (requires cert and key files)
# TLS_CERT_FILE: Absolute path to the TLS certificate file (PEM format)
# TLS_KEY_FILE: Absolute path to the TLS private key file (PEM format)
USE_TLS=false
TLS_CERT_FILE=/etc/ssl/certs/olt-api.pem
TLS_KEY_FILE=/etc/ssl/private/olt-api-key.pem

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------
# Cross-Origin Resource Sharing settings for browser-based API clients.
# CORS_ALLOWED_ORIGINS: Comma-separated list of allowed origins
#   Development: http://localhost:3000,http://localhost:8080
#   Production:  https://noc.example.com,https://dashboard.example.com
#   Wildcard:    * (allow all - NOT recommended for production)
# CORS_ALLOWED_METHODS: Comma-separated HTTP methods
# CORS_ALLOWED_HEADERS: Comma-separated request headers
# CORS_ALLOW_CREDENTIALS: Allow cookies/auth headers (true/false)
# CORS_MAX_AGE: Preflight cache duration in seconds
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-API-Key,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=300

# ------------------------------------------------------------------------------
# API Key Authentication
# ------------------------------------------------------------------------------
# Protect all /api/v1 routes with X-API-Key header validation.
# If empty or unset, authentication is disabled (open access).
# Example: generate with `openssl rand -hex 32`
API_KEY=
# API_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2
#
# Per-tenant access control (API_USERS) — OPTIONAL, overrides the single API_KEY.
# A JSON array mapping each X-API-Key to a user_id + role. Combined with the
# "user_id" field on each OLT in OLTS, a caller only sees the OLTs they own:
# requesting another tenant's OLT returns 404 (not 403 — no enumeration). A
# user with role "admin" sees ALL OLTs (for NOC/monitoring). An OLT with no
# user_id (0) is unowned and visible to admins only.
#   role: "user" (default) | "admin"
# When API_USERS is unset, the single API_KEY above applies unchanged.
# API_USERS=[{"user_id":1,"api_key":"keyA"},{"user_id":2,"api_key":"keyB"},{"user_id":0,"api_key":"adminKey","role":"admin"}]

# ------------------------------------------------------------------------------
# OLT Slot / PON Topology (C320 + C300) — single OLT
# ------------------------------------------------------------------------------
# OLT_BOARDS lists the PHYSICAL slots that hold GPON line cards, optionally with
# the card's PON-port count as "slot:pons". The OID encoding is identical for
# C320 and C300 — only the populated slots/cards differ:
#   - ZTE C320:  line cards in slots 1-2          -> OLT_BOARDS=1,2  (default)
#   - ZTE C300:  GTGH(16) in slot 3, GTGO(8) in 5 -> OLT_BOARDS=3:16,5:8
# A C300 has up to 14 service slots; each may hold a GTGO (8 PON) or GTGH (16 PON)
# card, mixed freely. Bare slots (no ":pons") use OLT_PONS_PER_BOARD as the default.
# board_id in the API path (/api/v1/board/{board_id}/...) is the physical slot.
OLT_BOARDS=1,2
OLT_PONS_PER_BOARD=16

# ------------------------------------------------------------------------------
# Multi-OLT in ONE instance (optional) — OLTS
# ------------------------------------------------------------------------------
# Set OLTS to a JSON array to manage MULTIPLE OLTs (any mix of C320/C300) from a
# single instance. When OLTS is set, the SNMP_*/OLT_BOARDS values above are
# ignored. Each OLT is reachable at /api/v1/olt/{id}/board/{slot}/pon/{pon}/...
# and the DEFAULT_OLT is also served at the bare /api/v1/board/... paths.
# Each OLT's Redis cache is namespaced by id, so they never collide.
#   "boards" supports per-slot PON counts ("3:16,5:8"); "port" defaults to 161.
#   "user_id" (optional) marks the OLT's owner for per-tenant access (see API_USERS).
# OLTS=[{"id":"c320","user_id":1,"host":"10.0.0.1","port":161,"community":"public","boards":"1,2"},{"id":"c300a","user_id":2,"host":"192.0.2.20","port":1161,"community":"public","boards":"3:16,5:8"}]
# DEFAULT_OLT=c320
#
# OLTS_FILE — alternative to inline OLTS: a path to a file holding the SAME JSON
# array. Preferred for many OLTs and for mounting community strings as a k8s
# Secret (the Helm chart's olt.oltsFile mounts it at /etc/olt/olts.json). Inline
# OLTS wins over OLTS_FILE. Loading is FAIL-FAST: a set-but-unreadable or empty
# file aborts startup rather than silently falling back to SNMP_*.
# OLTS_FILE=/etc/olt/olts.json

# ------------------------------------------------------------------------------
# OLT OID Configuration (Advanced)
# ------------------------------------------------------------------------------
# Override default ZTE C320 base OIDs. Only change if your OLT firmware
# uses non-standard OID paths. Leave unset to use built-in defaults.
# OLT_BASE_OID_1: Base OID for most ONU queries (default: .1.3.6.1.4.1.3902.1082)
# OLT_BASE_OID_2: Base OID for ONU type queries (default: .1.3.6.1.4.1.3902.1012)
# ONU_ID_NAME_PREFIX: OID prefix for ONU name (default: .500.10.2.3.3.1.2)
# ONU_TYPE_PREFIX: OID prefix for ONU type (default: .3.50.11.2.1.17)
# OLT_BASE_OID_1=.1.3.6.1.4.1.3902.1082
# OLT_BASE_OID_2=.1.3.6.1.4.1.3902.1012
# ONU_ID_NAME_PREFIX=.500.10.2.3.3.1.2
# ONU_TYPE_PREFIX=.3.50.11.2.1.17

# ------------------------------------------------------------------------------
# SNMP Trap Configuration
# ------------------------------------------------------------------------------
# Real-time ONU event monitoring via SNMP Trap listener.
# TRAP_ENABLED: Enable/disable the trap listener (true/false)
# TRAP_PORT: UDP port to listen for SNMP traps (default: 1620, use 162 for standard)
# TRAP_COMMUNITY: SNMP community for trap authentication (defaults to SNMP_COMMUNITY)
# TRAP_WEBHOOK_URL: HTTP endpoint to receive trap event notifications (JSON POST)
#   Leave empty to disable webhook notifications.
#   Example: https://discord.com/api/webhooks/<id>/<token>
#   Example: https://hooks.slack.com/services/T00/B00/xxx
#   Example: https://api.telegram.org/bot<token>/sendMessage
#   Example: https://noc.example.com/api/alerts
# TRAP_WEBHOOK_TYPE: Override auto-detected platform (discord|slack|telegram|generic)
#   Auto-detect from URL if empty. Use this when behind a proxy or custom domain.
# TRAP_WEBHOOK_CHAT_ID: Telegram chat/group ID (required when platform is telegram)
# TRAP_WEBHOOK_RETRIES: Number of retry attempts on webhook failure (0 = no retry)
# TRAP_WEBHOOK_TIMEOUT: HTTP timeout in seconds for each webhook request
TRAP_ENABLED=false
TRAP_PORT=1620
TRAP_COMMUNITY=public
TRAP_WEBHOOK_URL=
# TRAP_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefghijklmnop
# TRAP_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxx
# TRAP_WEBHOOK_URL=https://api.telegram.org/bot123456:ABC-DEF1234ghIkl-zyx57W2v
TRAP_WEBHOOK_TYPE=
# TRAP_WEBHOOK_TYPE=discord
# TRAP_WEBHOOK_TYPE=slack
# TRAP_WEBHOOK_TYPE=telegram
# TRAP_WEBHOOK_TYPE=generic
TRAP_WEBHOOK_CHAT_ID=
# TRAP_WEBHOOK_CHAT_ID=-1001234567890
# Per-severity batch intervals (seconds). Events are grouped by severity
# and sent as one batched message per interval. Set 0 to disable batching for that severity.
# CRITICAL: LOS, LOSi, LOFi, Offline, AuthFailed, PowerOff
# HIGH: Logging, Synchronization (stuck)
# MEDIUM: HighRxPower, LowRxPower
# LOW: DyingGasp
TRAP_CRITICAL_INTERVAL=300
TRAP_HIGH_INTERVAL=3600
TRAP_MEDIUM_INTERVAL=14400
TRAP_LOW_INTERVAL=28800
# Repeat notification interval (minutes). If ONU is still offline after this period,
# re-send notification. Set 0 to disable repeat (notify once only).
TRAP_CRITICAL_REPEAT=60
TRAP_HIGH_REPEAT=60
TRAP_MEDIUM_REPEAT=0
TRAP_LOW_REPEAT=0
# Per-severity action messages (displayed in webhook notifications).
# Configurable for i18n — set in your language, or leave empty for English defaults.
# TRAP_ACTION_CRITICAL=Mandatory customer visit within 1x24 hours
# TRAP_ACTION_HIGH=Mandatory visit within 1x24 hours if Hard Restart does not resolve
# TRAP_ACTION_MEDIUM=Mandatory visit within 2x24 hours after notification
# TRAP_ACTION_LOW=Coordinate with customer to ensure no electrical issues
# Example (Indonesian):
# TRAP_ACTION_CRITICAL=Wajib visit ke Customer maksimal 1x24 jam
# TRAP_ACTION_HIGH=Wajib visit maksimal 1x24 jam jika Hard Restart tidak Solved
# TRAP_ACTION_MEDIUM=Wajib visit maksimal 2x24 jam setelah notifikasi
# TRAP_ACTION_LOW=Koordinasi kepada Customer untuk memastikan tidak ada kendala kelistrikan
TRAP_WEBHOOK_RETRIES=3
TRAP_WEBHOOK_TIMEOUT=10

# ------------------------------------------------------------------------------
# RX Power Monitor
# ------------------------------------------------------------------------------
# Periodic scanning of all ONUs for abnormal optical power levels.
# Sends webhook alerts when RX power exceeds thresholds (overload or weak signal).
# Requires: TRAP_ENABLED=true AND TRAP_WEBHOOK_URL to be set.
#
# Scheduling modes (can combine both):
#   INTERVAL only:  POWER_MONITOR_INTERVAL=300, POWER_MONITOR_CRON=
#   CRON only:      POWER_MONITOR_INTERVAL=0,   POWER_MONITOR_CRON=0 8,12,15,17,0 * * *
#   Both:           POWER_MONITOR_INTERVAL=300,  POWER_MONITOR_CRON=0 8,12,15,17,0 * * *
#   Disabled:       POWER_MONITOR_INTERVAL=0,    POWER_MONITOR_CRON=
#
# POWER_MONITOR_ENABLED: Enable/disable the RX power scanner (true/false)
# POWER_MONITOR_INTERVAL: Scan interval in seconds (0 = disable interval mode)
# POWER_MONITOR_CRON: Cron expression for scheduled scans (5-field standard cron)
#   Examples:
#     0 8,12,15,17,0 * * *    = at 08:00, 12:00, 15:00, 17:00, 00:00
#     */30 * * * *             = every 30 minutes
#     0 */2 * * *              = every 2 hours
#     0 6 * * 1-5              = weekdays at 06:00
# POWER_MONITOR_TIMEZONE: IANA timezone for cron schedule (empty = server local time)
#   Examples: Asia/Jakarta, Asia/Makassar, UTC, America/New_York
# RX_POWER_HIGH_THRESHOLD: Alert when RX power exceeds this value in dBm (overload risk)
# RX_POWER_LOW_THRESHOLD: Alert when RX power drops below this value in dBm (weak signal)
POWER_MONITOR_ENABLED=false
POWER_MONITOR_INTERVAL=300
POWER_MONITOR_CRON=
POWER_MONITOR_TIMEZONE=Asia/Jakarta
RX_POWER_HIGH_THRESHOLD=-8.0
RX_POWER_LOW_THRESHOLD=-25.0

# ------------------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------------------
TZ=Asia/Jakarta

# ── device-registry (live registry source, Stage 2) ──────────────────
# When set, this adapter sources its device list from device-registry instead
# of the static env/file registry above — so adding a device there needs no
# reconfig. mikrotik-svc + write-olt-zte hot-reload (no restart, REGISTRY_REFRESH
# seconds); snmp-olt-zte reads at startup (a restart picks up new OLTs).
# REGISTRY_URL=http://device-registry:3050
# REGISTRY_API_KEY=
# REGISTRY_REFRESH=30
# On a cold cluster start snmp-olt-zte often boots before device-registry is
# Ready. Rather than crash-loop, the startup registry fetch retries with backoff
# for this long before giving up (a genuinely-unreachable registry still fails
# fast — there is no silent fallback to stale config). Go duration; "0" disables
# the retry (single attempt, fail-fast). Default 60s.
# REGISTRY_STARTUP_TIMEOUT=60s
