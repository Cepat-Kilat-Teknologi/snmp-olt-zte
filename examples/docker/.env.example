# ============================================================
# SNMP OLT ZTE C320 -- Environment Variables
# Copy to .env and edit with your actual values.
# ============================================================

# --- Application ---
APP_ENV=production
SERVER_PORT=8081

# --- SNMP (REQUIRED) ---
SNMP_HOST=192.168.1.100
SNMP_PORT=161
SNMP_COMMUNITY=public
SNMP_MAX_CONCURRENT=5

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password
REDIS_DB=0
REDIS_MIN_IDLE_CONNECTIONS=10
REDIS_POOL_SIZE=100
REDIS_POOL_TIMEOUT=240

# --- Cache TTLs (seconds) ---
REDIS_ONU_INFO_TTL=1800
REDIS_ONU_DETAIL_TTL=900
REDIS_EMPTY_ONU_ID_TTL=300
CACHE_PREWARM=true

# --- TLS / HTTPS ---
USE_TLS=false
TLS_CERT_FILE=/certs/cert.pem
TLS_KEY_FILE=/certs/key.pem

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-API-Key,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=300

# --- Authentication ---
API_KEY=your-api-key-here

# --- SNMP Trap Listener ---
TRAP_ENABLED=false
TRAP_PORT=1620
TRAP_COMMUNITY=public
TRAP_WEBHOOK_URL=https://hooks.example.com/snmp-alerts
TRAP_WEBHOOK_TYPE=
TRAP_WEBHOOK_CHAT_ID=
TRAP_WEBHOOK_RETRIES=3
TRAP_WEBHOOK_TIMEOUT=10
TRAP_CRITICAL_INTERVAL=300
TRAP_HIGH_INTERVAL=3600
TRAP_MEDIUM_INTERVAL=14400
TRAP_LOW_INTERVAL=28800

# --- RX Power Monitor ---
POWER_MONITOR_ENABLED=false
POWER_MONITOR_INTERVAL=300
POWER_MONITOR_CRON=0 8,12,17 * * *
POWER_MONITOR_TIMEZONE=Asia/Jakarta
RX_POWER_HIGH_THRESHOLD=-8.0
RX_POWER_LOW_THRESHOLD=-25.0

# --- Timezone ---
TZ=Asia/Jakarta
