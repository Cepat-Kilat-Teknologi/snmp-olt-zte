###############################################
# Go SNMP OLT ZTE C320 - API Test Collection
# Base URL: http://localhost:8081
# OpenAPI Spec: api/openapi.yaml
###############################################

### Health Check
GET http://localhost:8081/health
Accept: application/json

### Root Endpoint
GET http://localhost:8081/
Accept: application/json

###############################################
# ONU Information Endpoints
# Requires X-API-Key header when API_KEY is set
###############################################

### Get All ONUs by Board and PON
GET http://localhost:8081/api/v1/board/2/pon/7
Accept: application/json
X-API-Key: {{API_KEY}}

### Get All ONUs - Board 1 PON 8
GET http://localhost:8081/api/v1/board/1/pon/8
Accept: application/json
X-API-Key: {{API_KEY}}

### Get Specific ONU by Board, PON, and ONU ID
GET http://localhost:8081/api/v1/board/1/pon/8/onu/11
Accept: application/json
X-API-Key: {{API_KEY}}

### Get Specific ONU - Board 2 PON 7 ONU 4
GET http://localhost:8081/api/v1/board/2/pon/7/onu/4
Accept: application/json
X-API-Key: {{API_KEY}}

###############################################
# Empty ONU ID Endpoints
###############################################

### Get Empty ONU IDs
GET http://localhost:8081/api/v1/board/1/pon/8/onu_id/empty
Accept: application/json
X-API-Key: {{API_KEY}}

### Get Empty ONU IDs - Board 2 PON 5
GET http://localhost:8081/api/v1/board/2/pon/5/onu_id/empty
Accept: application/json
X-API-Key: {{API_KEY}}

### Update Empty ONU ID Cache (POST)
POST http://localhost:8081/api/v1/board/1/pon/8/onu_id/update
Accept: application/json
X-API-Key: {{API_KEY}}

### Update Empty ONU IDs - Board 2 PON 5 (POST)
POST http://localhost:8081/api/v1/board/2/pon/5/onu_id/update
Accept: application/json
X-API-Key: {{API_KEY}}

###############################################
# ONU ID and Serial Number Endpoint
###############################################

### Get ONU IDs with Serial Numbers
GET http://localhost:8081/api/v1/board/1/pon/8/onu_id_sn
Accept: application/json
X-API-Key: {{API_KEY}}

### Get ONU IDs with Serial Numbers - Board 2 PON 7
GET http://localhost:8081/api/v1/board/2/pon/7/onu_id_sn
Accept: application/json
X-API-Key: {{API_KEY}}

###############################################
# Pagination Endpoints
###############################################

### Get ONUs with Pagination - Default (page 1, limit 10)
GET http://localhost:8081/api/v1/paginate/board/1/pon/8
Accept: application/json
X-API-Key: {{API_KEY}}

### Get ONUs with Pagination - Page 2 with Limit 5
GET http://localhost:8081/api/v1/paginate/board/1/pon/8?page=2&limit=5
Accept: application/json
X-API-Key: {{API_KEY}}

### Get ONUs with Pagination - Board 2 PON 8
GET http://localhost:8081/api/v1/paginate/board/2/pon/8?limit=3&page=2
Accept: application/json
X-API-Key: {{API_KEY}}

###############################################
# Cache Management Endpoints
###############################################

### Delete Cache for Board/PON
DELETE http://localhost:8081/api/v1/board/1/pon/8/cache/clear
Accept: application/json
X-API-Key: {{API_KEY}}

### Delete Cache - Board 2 PON 7
DELETE http://localhost:8081/api/v1/board/2/pon/7/cache/clear
Accept: application/json
X-API-Key: {{API_KEY}}

###############################################
# Error Testing - Invalid Parameters
###############################################

### Invalid Board ID (expect 400)
GET http://localhost:8081/api/v1/board/99/pon/1
Accept: application/json
X-API-Key: {{API_KEY}}

### Invalid PON ID (expect 400)
GET http://localhost:8081/api/v1/board/1/pon/99
Accept: application/json
X-API-Key: {{API_KEY}}

### Invalid ONU ID (expect 400)
GET http://localhost:8081/api/v1/board/1/pon/1/onu/999
Accept: application/json
X-API-Key: {{API_KEY}}

### Missing API Key (expect 401 when API_KEY is set)
GET http://localhost:8081/api/v1/board/1/pon/1
Accept: application/json

###############################################
# Notes:
# - Set {{API_KEY}} variable or leave empty if auth disabled
# - Health and root endpoints don't require auth
# - Default timeout: 90 seconds
# - Rate limit: 100 req/s, burst 200
# - Cache TTL: 10 minutes
# - Board IDs: 1 or 2
# - PON IDs: 1-16
# - ONU IDs: 1-128
###############################################
